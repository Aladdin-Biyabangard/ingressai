# Local course-ms (see https://ingress.academy for production paths)
VITE_API_DOMAIN=http://localhost:4000
VITE_BASE_URL=course-ms/api

# Local chat-ms — adjust path if your service mounts at root (e.g. http://localhost:9190 only)
VITE_CHAT_MS_URL=http://localhost:9190/api

# Local categories list uses …/v1/categories/search?page=&size=
VITE_COURSE_CATEGORIES_USE_SEARCH=true
